---
import BaseLayout from '../layouts/BaseLayout.astro';
import HubRecipes from '../components/HubRecipes.astro';
---

<BaseLayout
  title="Community Hub — OpenCastor"
  description="Share, discover, and remix robot recipes. Browse community-tested RCAN configs for home, outdoor, industrial, and agricultural robots."
  ogUrl="https://opencastor.com/hub"
>

<main>

    <!-- ======== HERO ======== -->
    <section class="page-hero" style="padding-bottom:20px">
      <p class="section-label reveal">Community Hub</p>
      <h1 class="reveal reveal-d1">OpenCastor<br><span class="gradient-text">Community Hub</span></h1>
      <p class="reveal reveal-d2" style="font-size:1.25rem;max-width:540px;margin:0 auto 36px">Share, discover, and
        remix robot recipes — configs that real builders have tested on real hardware.</p>
      <div class="hero-actions reveal reveal-d3">
        <a href="#recipes" class="btn btn-primary btn-lg">
          Browse Recipes
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </section>

    <!-- ======== COMMUNITY STATS ======== -->
    <section class="community-stats-bar">
      <div class="container">
        <div class="community-stats-grid">
          <div class="community-stat reveal">
            <div class="community-stat-number">25+</div>
            <div class="community-stat-label">Configs &amp; Skills</div>
          </div>
          <div class="community-stat reveal reveal-d1">
            <div class="community-stat-number">8</div>
            <div class="community-stat-label">AI Providers</div>
          </div>
          <div class="community-stat reveal reveal-d2">
            <div class="community-stat-number">3</div>
            <div class="community-stat-label">GitHub Stars</div>
          </div>
          <div class="community-stat reveal reveal-d3">
            <div class="community-stat-number">106</div>
            <div class="community-stat-label">Tests Passing</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Recipes grid loaded as external Astro component -->
    <HubRecipes />

    <!-- ======== GET INVOLVED ======== -->
    <section class="section alt-section" id="get-involved">
      <div class="container">
        <div class="section-header center reveal">
          <p class="section-label">Get Involved</p>
          <h2 class="section-title">Help expand the ecosystem.</h2>
          <p class="section-desc">Join the community and help build the universal embodied AI runtime.</p>
        </div>

        <div class="bento">
          <div class="card reveal">
            <div class="card-icon" style="background:var(--accent-glow)">🤖</div>
            <h3>Read the Guides</h3>
            <p>Ready to build a recipe? Learn how to structure your RCAN configuration and use the Castor CLI tool.</p>
            <div style="margin-top:20px">
              <a href="/docs/setup-wizard" style="color:var(--accent);font-size:0.875rem;font-weight:600">CLI Documentation &rarr;</a>
            </div>
          </div>

          <div class="card reveal reveal-d1">
            <div class="card-icon" style="background:var(--red-light)">🛡️</div>
            <h3>Safety & Protocol 66</h3>
            <p>Ensure your hardware recipes comply with core physical bounds safety invariants to avoid robot malfunction or damage.</p>
            <div style="margin-top:20px">
              <a href="/docs/safety" style="color:var(--accent);font-size:0.875rem;font-weight:600">Read the P66 Rules &rarr;</a>
            </div>
          </div>

          <div class="card reveal reveal-d2">
            <div class="card-icon" style="background:var(--blue-light)">📚</div>
            <h3>Provide a Fix</h3>
            <p>Docs live right here in our active GitHub. Found a confusing section? Missing example? Feel free to open a PR.</p>
            <div style="margin-top:20px">
              <a href="https://github.com/craigm26/OpenCastor/blob/main/CONTRIBUTING.md" style="color:var(--accent);font-size:0.875rem;font-weight:600">See CONTRIBUTING.md &rarr;</a>
            </div>
          </div>

          <div class="card reveal reveal-d3">
            <div class="card-icon" style="background:var(--purple-light)">🔌</div>
            <h3>Build an AI Provider</h3>
            <p>Add support for a new AI provider inside the codebase. The `BaseProvider` interface is a clean 50-line contract.</p>
            <div style="margin-top:20px">
              <a href="/docs/providers" style="color:var(--accent);font-size:0.875rem;font-weight:600">Provider guide &rarr;</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ======== SOCIAL / CTA ======== -->
    <section class="cta-section" style="padding-top:40px">
      <h2 class="reveal">Every working config helps someone.</h2>
      <p class="reveal reveal-d1">Share yours. Find your next build. Build together.</p>
      
      <div class="community-social-links reveal reveal-d3" style="justify-content:center;margin-top:32px">
        <a href="https://github.com/craigm26/OpenCastor" class="community-social-link">
          <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
            <path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.17 6.839 9.49.5.09.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836a9.59 9.59 0 012.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.167 22 16.418 22 12c0-5.523-4.477-10-10-10z" />
          </svg>
          GitHub
        </a>
        <a href="https://pypi.org/project/opencastor/" class="community-social-link">
          <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
            <path d="M9.585 11.692h4.328s2.432.039 2.432-2.35V5.391S16.714 3 11.936 3C7.362 3 7.647 4.983 7.647 4.983l.006 2.055h4.363v.617H5.92S3 7.28 3 11.874s2.547 4.456 2.547 4.456h1.521v-2.143s-.083-2.547 2.508-2.547l-.001.052zm-.282-4.444a.812.812 0 110-1.624.812.812 0 010 1.624z" />
            <path d="M14.415 12.308h-4.328s-2.432-.039-2.432 2.35v3.951S7.286 21 12.064 21c4.574 0 4.289-1.983 4.289-1.983l-.006-2.055h-4.363v-.617h6.096S21 16.72 21 12.126s-2.547-4.456-2.547-4.456h-1.521v2.143s.083 2.547-2.508 2.547l.001-.052zm.282 4.444a.812.812 0 110 1.624.812.812 0 010-1.624z" />
          </svg>
          PyPI
        </a>
        <a href="https://discord.gg/jMjA8B26Bq" class="community-social-link">
          <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
            <path d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03z" />
          </svg>
          Discord Community
        </a>
      </div>
    </section>

  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-grid">
        <div class="footer-brand">
          <a href="/" class="nav-logo">
            <div class="nav-logo-img"></div>
            <span>OpenCastor</span>
          </a>
          <p>The universal runtime for embodied AI. Give any robot a brain.</p>
        </div>
        <div class="footer-col">
          <h4>Product</h4>
          <a href="/docs">Documentation</a>
          <a href="/hardware">Hardware</a>
          <a href="/hub">Community Hub</a>
          <a href="https://rcan.dev/spec/">RCAN Spec</a>
        </div>
        <div class="footer-col">
          <h4>Resources</h4>
          <a href="/docs">Getting Started</a>
          <a href="https://github.com/craigm26/OpenCastor">GitHub</a>
          <a href="https://github.com/craigm26/OpenCastor/issues">Issues</a>
          <a href="https://discord.gg/jMjA8B26Bq">Discord Community</a>
        </div>
        <div class="footer-col">
          <h4>Community</h4>
          <a href="/hub">Recipe Hub</a>
          <a href="https://github.com/craigm26/OpenCastor/blob/main/CONTRIBUTING.md">Contributing</a>
          <a href="https://pypi.org/project/opencastor/">PyPI</a>
          <a href="/about">About</a>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; 2025-2026 Craig Merry. Apache 2.0 License.</p>
      </div>
    </div>
  </footer>

<script is:inline>
  // Theme pill — clicking ☀ or 🌙 sets that theme directly; clicking pill body toggles
  (function() {
    var t = localStorage.getItem('oc-theme');
    var dark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    document.documentElement.setAttribute('data-theme', t || (dark ? 'dark' : 'light'));
  })();

  document.addEventListener('DOMContentLoaded', function() {
    function applyTheme(theme) {
      document.documentElement.setAttribute('data-theme', theme);
      localStorage.setItem('oc-theme', theme);
    }
    document.querySelectorAll('.theme-pill').forEach(function(pill) {
      pill.addEventListener('click', function(e) {
        var opt = e.target.closest('[data-opt]');
        if (opt) {
          applyTheme(opt.dataset.opt);
        } else {
          var cur = document.documentElement.getAttribute('data-theme') || 'dark';
          applyTheme(cur === 'dark' ? 'light' : 'dark');
        }
      });
    });
  });
</script>

</BaseLayout>
