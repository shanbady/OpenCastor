{
  "__inputs": [],
  "__elements": {},
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.4.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"}
  ],
  "annotations": {"list": []},
  "description": "OpenCastor Robot Telemetry Dashboard — 6 panels for loop latency, commands, provider health, driver mode, errors, and memory.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Loop Latency p50 / p95 (ms)",
      "type": "timeseries",
      "description": "Perception-action loop latency at the 50th and 95th percentiles.",
      "datasource": {"type": "prometheus", "uid": "opencastor-prometheus"},
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 10}
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "opencastor-prometheus"},
          "expr": "histogram_quantile(0.50, rate(opencastor_action_latency_ms_bucket[1m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "opencastor-prometheus"},
          "expr": "histogram_quantile(0.95, rate(opencastor_action_latency_ms_bucket[1m]))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ],
      "options": {"tooltip": {"mode": "multi"}}
    },
    {
      "id": 2,
      "title": "Commands per Minute",
      "type": "timeseries",
      "description": "Rate of API commands processed per minute.",
      "datasource": {"type": "prometheus", "uid": "opencastor-prometheus"},
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "color": {"mode": "fixed", "fixedColor": "green"},
          "custom": {"lineWidth": 2, "fillOpacity": 15}
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "opencastor-prometheus"},
          "expr": "rate(opencastor_commands_total[1m]) * 60",
          "legendFormat": "commands/min",
          "refId": "A"
        }
      ],
      "options": {"tooltip": {"mode": "single"}}
    },
    {
      "id": 3,
      "title": "Provider Health",
      "type": "gauge",
      "description": "Current LLM provider health score (1 = healthy, 0 = degraded).",
      "datasource": {"type": "prometheus", "uid": "opencastor-prometheus"},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 0.5},
              {"color": "green", "value": 0.8}
            ]
          },
          "color": {"mode": "thresholds"}
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 6, "x": 0, "y": 8},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "opencastor-prometheus"},
          "expr": "opencastor_safety_score",
          "legendFormat": "safety score",
          "refId": "A"
        }
      ],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto"}
    },
    {
      "id": 4,
      "title": "Active Driver Mode",
      "type": "stat",
      "description": "The current active driver mode (e.g. differential, rc, ros2).",
      "datasource": {"type": "prometheus", "uid": "opencastor-prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "fixed", "fixedColor": "blue"},
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 6, "x": 6, "y": 8},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "opencastor-prometheus"},
          "expr": "opencastor_driver_mode",
          "legendFormat": "{{mode}}",
          "refId": "A"
        }
      ],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "auto", "graphMode": "none"}
    },
    {
      "id": 5,
      "title": "Error Rate by Code",
      "type": "timeseries",
      "description": "Rate of errors grouped by HTTP status code or error type.",
      "datasource": {"type": "prometheus", "uid": "opencastor-prometheus"},
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 10}
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "opencastor-prometheus"},
          "expr": "rate(opencastor_errors_total[1m])",
          "legendFormat": "{{code}}",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "opencastor-prometheus"},
          "expr": "rate(opencastor_brain_errors[1m])",
          "legendFormat": "brain/{{provider}}",
          "refId": "B"
        }
      ],
      "options": {"tooltip": {"mode": "multi"}}
    },
    {
      "id": 6,
      "title": "Memory Episodes Count",
      "type": "stat",
      "description": "Total number of episodes stored in the robot's episode memory.",
      "datasource": {"type": "prometheus", "uid": "opencastor-prometheus"},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 5000},
              {"color": "red", "value": 9000}
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "opencastor-prometheus"},
          "expr": "opencastor_memory_episodes_total",
          "legendFormat": "episodes",
          "refId": "A"
        }
      ],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "auto", "graphMode": "area"}
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["opencastor", "robot", "telemetry"],
  "templating": {"list": []},
  "time": {"from": "now-30m", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "OpenCastor Robot Telemetry",
  "uid": "opencastor-telemetry",
  "version": 1,
  "weekStart": ""
}
